server {
    listen 80;
    server_name genext.online www.genext.online 13.60.209.165;

    location = /favicon.ico { access_log off; log_not_found off; }
    
    location /static/ {
        alias /home/ubuntu/sbi-lms/staticfiles/;
    }

    location /media/ {
        alias /home/ubuntu/sbi-lms/media/;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/run/gunicorn.socket;
    }
}
